# Required - JWT signing secret. Use a long random string (e.g. openssl rand -hex 64).
# The server will refuse to start if this variable is not set.
JWT_SECRET=your-secret-here

# Comma-separated CORS allowlist. Example:
# ALLOWED_ORIGINS=https://app.nextellar.dev,https://admin.nextellar.dev
ALLOWED_ORIGINS=

# Timeout for GET /exchange-rate outbound request in milliseconds.
# Defaults to 5000 if unset or invalid.
EXCHANGE_RATE_TIMEOUT_MS=5000

# Internal API key for accessing /health/detailed endpoint.
# Use a strong random string (e.g. openssl rand -hex 32).
INTERNAL_API_KEY=your-internal-key-here

# Application version for health diagnostics.
APP_VERSION=1.0.0

# Database host for health diagnostics.
DB_HOST=localhost
